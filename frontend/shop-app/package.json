    "@tensorflow/tfjs-backend-webgl": "^3.21.0",
    "@tensorflow/tfjs-core": "^3.21.0",
    "@theatre/core": "^0.7.2",
    "@threlte/core": "^7.3.1",
    "@threlte/extras": "^8.12.1",
    "@threlte/theatre": "^2.1.8",
    "@threlte/xr": "^0.1.4",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
    "camera-controls": "^2.9.0",
    "postcss": "^8.4.38",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^3.4.3",
    "three": "^0.159.0"
  }
